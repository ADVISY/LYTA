# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# Legacy alias still supported by the frontend:
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (Supabase Edge Function secrets)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio (Supabase Edge Function secrets)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+41...
# TWILIO_VERIFY_SERVICE_SID=VA...

# Email (Supabase Edge Function secrets)
# RESEND_API_KEY=re_...

# CORS (Supabase Edge Function secrets)
# Supports exact origins and wildcard subdomains such as https://*.lyta.ch
# ALLOWED_ORIGINS=https://lyta.ch,https://app.lyta.ch,https://*.lyta.ch,http://localhost:5173

# AI (Supabase Edge Function secrets)
# OPENAI_API_KEY=sk-...
# AI_GATEWAY_API_KEY=... (alternative to OPENAI_API_KEY)
# AI_MODEL=gpt-4o-mini

# Cloudflare DNS (Supabase Edge Function secrets)
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ZONE_ID=...
# TENANT_DOMAIN_SUFFIX=lyta.ch
# TENANT_CNAME_TARGET=cname.vercel-dns.com
# TENANT_CNAME_PROXIED=false

# Vercel domains (Supabase Edge Function secrets)
# VERCEL_TOKEN=...
# VERCEL_PROJECT_ID=prj_...
# VERCEL_TEAM_ID=team_...
# VERCEL_TEAM_SLUG=... # optional if VERCEL_TEAM_ID is set
